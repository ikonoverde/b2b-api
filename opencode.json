{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "laravel-telescope": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "/home/eric/projects/b2b/api/artisan",
                "telescope-mcp:server"
            ],
            "environment": {
                "APP_ENV": "local"
            }
        }
    }
}
