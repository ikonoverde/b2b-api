{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "linear": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-remote",
                "https://mcp.linear.app/mcp"
            ]
        },
        "laravel-telescope": {
            "command": "php",
            "args": [
                "artisan",
                "telescope-mcp:server"
            ],
            "env": {
                "APP_ENV": "local"
            },
            "cwd": "/home/eric/projects/b2b/api"
        },
        "formulas": {
            "type": "http",
            "url": "https://produccion.ikonoverde.com/mcp/formulas"
        },
        "dataforseo": {
            "type": "http",
            "url": "http://localhost:3030/mcp"
        }
    }
}
