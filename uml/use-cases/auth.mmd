graph LR
    subgraph Actors
        Guest((Guest))
        AuthUser((Authenticated User))
    end

    subgraph "Authentication Use Cases"
        Register[Register<br/>POST /api/register]
        Login[Login<br/>POST /api/login]
        ForgotPassword[Forgot Password<br/>POST /api/forgot-password]
        ChangePassword[Change Password<br/>PUT /api/password]
        GetUser[Get Profile<br/>GET /api/user]
        UpdateUser[Update Profile<br/>PUT /api/user]
    end

    Guest --> Register
    Guest --> Login
    Guest --> ForgotPassword

    AuthUser --> ChangePassword
    AuthUser --> GetUser
    AuthUser --> UpdateUser

    ChangePassword -. "invalidates other tokens" .-> InvalidateTokens[Invalidate Other Tokens]
    ChangePassword -. "validates via" .-> CurrentPasswordCheck[Verify Current Password]
